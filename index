              if (c.minor) parts.push(c.minor);
              if (c.sub) parts.push(c.sub);
              let subLabel = parts.filter(Boolean).join(' - ');
              return `
                <div class="row-item" style="padding-left:42px; border-bottom:1px solid #F2F4F6;">
